DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
FORCE_SCRIPT_NAME=
SESSION_COOKIE_NAME=nav_sessionid
CSRF_COOKIE_NAME=nav_csrftoken
POSTGRES_DB=nav_reports
POSTGRES_USER=nav_app
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# Docker Compose sets DATABASE_HOST=db. DATABASE_URL is an optional alternative
# for non-Compose deployments and must contain URL-encoded credentials.
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_URL=
FRED_API_KEY=
RFR_HTTP_TIMEOUT=15
REPORT_CONVERSION_TIMEOUT=120
LIBREOFFICE_BINARY=soffice
MAX_UPLOAD_BYTES=10485760
LOG_LEVEL=INFO
TIME_ZONE=Asia/Hong_Kong
BIND_ADDRESS=127.0.0.1
HTTP_PORT=8000
SESSION_COOKIE_AGE=28800
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
